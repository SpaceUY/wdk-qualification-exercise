{
  "name": "wdk-qualification-exercise",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "turbo run start",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "turbo run test:e2e --filter=backend",
    "lint": "turbo run lint",
    "build:worklet": "turbo run build:worklet",
    "infra:dev": "npx sst deploy --stage dev",
    "infra:prod": "npx sst deploy --stage production",
    "infra:remove:dev": "npx sst remove --stage dev",
    "infra:output": "npx sst output"
  },
  "devDependencies": {
    "sst": "^3",
    "turbo": "^2.3.3"
  }
}
