# ── Ethereum Sepolia ──────────────────────────────────────────────────────────
# Public: https://rpc.sepolia.org
# Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
EXPO_PUBLIC_ETHEREUM_RPC_URL=https://rpc.sepolia.org

# ── Arbitrum Sepolia ──────────────────────────────────────────────────────────
# Public, no API key required
EXPO_PUBLIC_ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# No test-USDT contract deployed here yet — USDT (Arbitrum) is filtered out of the dashboard's
# balance list until this is set (see EVM_ASSETS in config/assets.ts), but still selectable (and
# will fail against the zero address) from the Send screen's token picker.
EXPO_PUBLIC_USDT_ARB_ADDRESS=

# ── Polygon Amoy ──────────────────────────────────────────────────────────────
# Public, no API key required
EXPO_PUBLIC_POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
# Same caveat as EXPO_PUBLIC_USDT_ARB_ADDRESS above — no test-USDT contract deployed here yet.
EXPO_PUBLIC_USDT_POL_ADDRESS=

# ── Bitcoin Mainnet (Blockbook) ───────────────────────────────────────────────
# btc1.trezor.io is Cloudflare-blocked for API requests (403 HTML, not JSON) — use this
# public, unauthenticated, verified-live mainnet Blockbook instance instead.
EXPO_PUBLIC_BTC_BLOCKBOOK_URL=https://blockbook.btc.zelcore.io/api

# ── Spark (Lightning L2, regtest) ─────────────────────────────────────────────
# Optional — the wallet boots and generates addresses without it; balance/transfer queries
# against SparkScan will fail without a real key.
EXPO_PUBLIC_SPARK_SCAN_API_KEY=

# ── Tron (Nile testnet, USDT-TRC20) ───────────────────────────────────────────
# Public, no API key required (only Tron mainnet enforces one)
EXPO_PUBLIC_TRON_RPC_URL=https://nile.trongrid.io
# No canonical test-USDT contract exists on Nile — source or deploy one, ideally the SAME
# contract address the self-hosted backend indexer (infra/wdk-stack's TRON_USDT_CONTRACT) uses,
# so both halves of the stack watch the same token.
EXPO_PUBLIC_USDT_TRON_ADDRESS=

# ── Token Addresses ───────────────────────────────────────────────────────────
# Set these once the test ERC-20 (USDT mock) and UTL contracts are deployed.
# Addresses MUST be lowercase (WDK normalizes contract address casing).
EXPO_PUBLIC_USDT_ETH_ADDRESS=0x0000000000000000000000000000000000000000

# UTL Utility Token — set after deploying the ERC-20 contract (sub-project 3)
EXPO_PUBLIC_UTL_ADDRESS=0x0000000000000000000000000000000000000000

# ── Google OAuth (Android Google Drive backup) ────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Enable the Google Drive API and create:
#   1. OAuth 2.0 Web client ID   (used for token exchange)
#   2. OAuth 2.0 Android client ID  (package: com.spacedev.rnwdkexercise)
# Add authorized redirect URI: rn-wdk-exercise://
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxxx.apps.googleusercontent.com

# ── AWS Cognito ───────────────────────────────────────────────────────────────
# Hosted UI domain (no trailing slash)
EXPO_PUBLIC_COGNITO_DOMAIN=https://your-pool.auth.us-east-1.amazoncognito.com
# App client ID (public client — no secret)
EXPO_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Backend API ───────────────────────────────────────────────────────────────
# apps/backend's local dev port (moved to 3001 to avoid colliding with the self-hosted
# WDK stack's app-node, which owns port 3000 — see EXPO_PUBLIC_APP_NODE_URL below).
EXPO_PUBLIC_API_URL=http://localhost:3001

# ── Self-hosted WDK stack app-node (infra/wdk-stack) ───────────────────────────
# Used directly by the app for wallet registration + transaction history — a separate
# service/auth scheme from the backend above (its own JWT, minted via
# GET /wdk-app-node/token on the backend, not the Cognito token used everywhere else).
EXPO_PUBLIC_APP_NODE_URL=http://localhost:3000
