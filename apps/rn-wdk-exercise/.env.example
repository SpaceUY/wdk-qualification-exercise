# ── Ethereum Sepolia ──────────────────────────────────────────────────────────
# Public: https://rpc.sepolia.org
# Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
EXPO_PUBLIC_ETHEREUM_RPC_URL=https://rpc.sepolia.org

# ── Arbitrum Sepolia ──────────────────────────────────────────────────────────
EXPO_PUBLIC_ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ── Polygon Amoy (not Mumbai — that network is deprecated) ───────────────────
EXPO_PUBLIC_POLYGON_RPC_URL=https://rpc-amoy.polygon.technology

# ── Bitcoin Testnet (Blockbook) ───────────────────────────────────────────────
EXPO_PUBLIC_BTC_BLOCKBOOK_URL=https://tbtc1.trezor.io

# ── Token Addresses ───────────────────────────────────────────────────────────
# Set these once the test ERC-20 (USDT mock) and UTL contracts are deployed.
# Addresses MUST be lowercase (WDK normalizes contract address casing).
EXPO_PUBLIC_USDT_ETH_ADDRESS=0x0000000000000000000000000000000000000000
EXPO_PUBLIC_USDT_ARB_ADDRESS=0x0000000000000000000000000000000000000000
EXPO_PUBLIC_USDT_POL_ADDRESS=0x0000000000000000000000000000000000000000

# UTL Utility Token — set after deploying the ERC-20 contract (sub-project 3)
EXPO_PUBLIC_UTL_ADDRESS=0x0000000000000000000000000000000000000000

# ── Google OAuth (Android Google Drive backup) ────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Enable the Google Drive API and create:
#   1. OAuth 2.0 Web client ID   (used for token exchange)
#   2. OAuth 2.0 Android client ID  (package: com.spacedev.rnwdkexercise)
# Add authorized redirect URI: rn-wdk-exercise://
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxxx.apps.googleusercontent.com
