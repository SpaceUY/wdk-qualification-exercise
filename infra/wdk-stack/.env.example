# Copy to .env (gitignored) and fill in. See README.md for the full bring-up runbook.

# --- Fork sources, used by scripts/clone-forks.sh ---
WDK_INDEXER_EVM_REPO=git@github.com:SpaceUY/wdk-indexer-wrk-evm.git
WDK_INDEXER_EVM_REF=main
WDK_INDEXER_PROCESSOR_REPO=git@github.com:SpaceUY/wdk-indexer-processor-wrk.git
WDK_INDEXER_PROCESSOR_REF=main
WDK_DATA_SHARD_REPO=git@github.com:SpaceUY/wdk-data-shard-wrk.git
WDK_DATA_SHARD_REF=main
WDK_ORK_REPO=git@github.com:SpaceUY/wdk-ork-wrk.git
WDK_ORK_REF=main
WDK_APP_NODE_REPO=git@github.com:SpaceUY/wdk-app-node.git
WDK_APP_NODE_REF=main
WDK_INDEXER_BTC_REPO=git@github.com:SpaceUY/wdk-indexer-wrk-btc.git
WDK_INDEXER_BTC_REF=main
WDK_INDEXER_SPARK_REPO=git@github.com:SpaceUY/wdk-indexer-wrk-spark.git
WDK_INDEXER_SPARK_REF=main
WDK_INDEXER_TRON_REPO=git@github.com:SpaceUY/wdk-indexer-wrk-tron.git
WDK_INDEXER_TRON_REF=main

# --- GitHub PAT for `docker compose build` (private git+https npm deps: @tetherto/*, @bitfinex/*) ---
GITHUB_PAT=

# --- Shared hRPC secrets — MUST be identical across all 5 services. Generate via scripts/gen-secrets.sh ---
WDK_CAPABILITY=
WDK_CRYPTO_KEY=

# --- wdk-app-node JWT signing secret. Generate via scripts/gen-secrets.sh ---
JWT_SECRET=

# --- Ethereum Sepolia RPC endpoint for the indexer ---
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com

# --- Filled in manually after first `docker compose up indexer-evm-proc data-shard-proc` ---
# (grep container logs for "rpc public key" — see README.md's two-phase bring-up section)
INDEXER_PROC_RPC_KEY=
DATA_SHARD_PROC_RPC_KEY=

# --- Bitcoin testnet RPC/Blockbook provider — no default ships upstream, must be a real
#     testnet-capable endpoint (e.g. a NOWNodes/QuickNode/Ankr testnet key, or self-run
#     `bitcoind -testnet`). Container fails fast at boot without this. ---
BTC_RPC_URL=

# --- SparkScan API key (regtest). Leave blank to boot the Spark indexer without live reads —
#     it will connect and 401 on the first real call rather than crash. ---
SPARK_API_KEY=

# --- Tron Nile testnet JSON-RPC — public, no API key required (only mainnet enforces one) ---
TRON_RPC_URL=https://nile.trongrid.io/jsonrpc

# --- Nile TRC20 USDT test-token contract address — no canonical one exists on Nile, must be
#     sourced or deployed. Container fails fast at boot without this. ---
TRON_USDT_CONTRACT=

# --- Filled in manually after first `docker compose up indexer-btc-proc indexer-spark-proc
#     indexer-tron-proc` (grep container logs for "rpc public key") ---
INDEXER_BTC_PROC_RPC_KEY=
INDEXER_SPARK_PROC_RPC_KEY=
INDEXER_TRON_PROC_RPC_KEY=
