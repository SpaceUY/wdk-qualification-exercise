{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:worklet": {
      "cache": false
    },
    "test": {},
    "test:e2e": {},
    "test:coverage": {
      "outputs": ["coverage/**"]
    },
    "lint": {},
    "start": {
      "persistent": true,
      "cache": false
    }
  }
}
